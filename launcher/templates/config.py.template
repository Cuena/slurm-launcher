# ---------------------------------------------------------------------------
# MN5 defaults
# ---------------------------------------------------------------------------

MN5_ACCOUNT = "your_mn5_account"
MAIL_USER: str | None = None
MAIL_TYPE = "END,FAIL"


def mn5_accel_sbatch(
    *,
    gpus: int = 1,
    qos: str = "acc_debug",
    job_time: str = "00-00:30:00",
) -> dict[str, Any]:
    cpus_per_task = max(1, 20 * max(1, gpus))
    return {
        "account": MN5_ACCOUNT,
        "qos": qos,
        "time": job_time,
        "ntasks": 1,
        "cpus-per-task": cpus_per_task,
        "gres": f"gpu:{max(1, gpus)}",
    }


def mn5_cpu_sbatch(
    *,
    qos: str = "gp_debug",
    job_time: str = "00-01:00:00",
) -> dict[str, Any]:
    return {
        "account": MN5_ACCOUNT,
        "qos": qos,
        "time": job_time,
        "ntasks": 1,
        "cpus-per-task": 1,
        "nodes": 1,
        "ntasks-per-node": 1,
    }


DEFAULT_ENV = {
    "PYTHONUNBUFFERED": "1",
}
DEFAULT_SBATCH = mn5_accel_sbatch(gpus=1)

if MAIL_USER:
    DEFAULT_SBATCH["mail-type"] = MAIL_TYPE
    DEFAULT_SBATCH["mail-user"] = MAIL_USER

